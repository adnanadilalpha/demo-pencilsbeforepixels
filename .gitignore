# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/build
.turbo

# production
/dist

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files & secrets (never commit)
.env
.env.*
!.env.example

# vercel
.vercel

# supabase local dev
.supabase/
/supabase/

# local scripts (seed/admin tooling)
/scripts/


# typescript
*.tsbuildinfo
next-env.d.ts

# editors / IDE
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# cursor (local agent/editor state)
.cursor/

# local design reference (not part of the app)
PBP.pdf
